{
  "name": "engine-ts",
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "imports": {
    "#3rdparty/*": "./src/3rdparty/*",
    "#/*": "./src/*",
    "#tools/*": "./tools/*"
  },
  "scripts": {
    "build": "tsx tools/pack/Build.ts",
    "clean": "tsx tools/pack/Clean.ts",
    "db:migrate": "tsx tools/server/prisma-multi.ts migrate deploy",
    "db:reset": "tsx tools/server/prisma-multi.ts migrate reset --force",
    "db:schema": "tsx tools/server/prisma-multi.ts migrate dev",
    "dev": "tsx --watch src/app.ts",
    "friend": "tsx src/friend.ts",
    "lint": "eslint --no-warn-ignored src tools",
    "logger": "tsx src/logger.ts",
    "login": "tsx src/login.ts",
    "prepare": "husky",
    "quickstart": "tsx src/app.ts",
    "setup": "npm install && tsx src/setup.ts",
    "sqlite:migrate": "prisma migrate deploy --schema prisma/singleworld/schema.prisma",
    "sqlite:reset": "prisma migrate reset --force --schema prisma/singleworld/schema.prisma",
    "sqlite:schema": "prisma migrate dev --schema prisma/singleworld/schema.prisma",
    "start": "npm install && tsx src/app.ts"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --no-warn-ignored"
    ]
  },
  "dependencies": {
    "@isaacs/ttlcache": "2.1.3",
    "@jimp/js-png": "1.6.0",
    "@jimp/plugin-quantize": "1.6.0",
    "@lostcityrs/runescript": "0.9.6",
    "bcrypt": "6.0.0",
    "ejs": "3.1.10",
    "fflate": "0.8.2",
    "jimp": "1.6.0",
    "kleur": "4.1.5",
    "kysely": "0.28.8",
    "mysql2": "3.15.3",
    "node-forge": "1.3.2",
    "prom-client": "15.1.3",
    "ws": "8.18.3"
  },
  "devDependencies": {
    "@eslint/js": "9.39.1",
    "@types/bcrypt": "6.0.0",
    "@types/ejs": "3.1.5",
    "@types/node": "24.10.1",
    "@types/node-forge": "1.3.14",
    "@types/ws": "8.18.1",
    "eslint": "9.39.1",
    "globals": "16.5.0",
    "husky": "9.1.7",
    "lint-staged": "16.2.7",
    "prettier": "3.7.3",
    "prisma": "6.16.3",
    "prisma-kysely": "2.2.1",
    "tsx": "4.21.1",
    "typescript-eslint": "8.48.1"
  },
  "peerDependencies": {
    "typescript": "5.8.3"
  }
}
