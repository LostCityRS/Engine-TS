{
  "name": "engine-ts",
  "version": "1.0.0",
  "type": "module",
  "imports": {
    "#3rdparty/*": "./src/3rdparty/*",
    "#/*": "./src/*",
    "#tools/*": "./tools/*"
  },
  "scripts": {
    "build": "bun run tools/pack/Build.ts",
    "clean": "bun run tools/pack/Clean.ts",
    "db:migrate": "bun run tools/server/prisma-multi.ts migrate deploy",
    "db:reset": "bun run tools/server/prisma-multi.ts migrate reset --force",
    "db:schema": "bun run tools/server/prisma-multi.ts migrate dev",
    "dev": "bun run --watch src/app.ts",
    "friend": "bun run src/friend.ts",
    "lint": "eslint --no-warn-ignored src tools",
    "logger": "bun run src/logger.ts",
    "login": "bun run src/login.ts",
    "node:build": "tsx tools/pack/Build.ts",
    "node:clean": "tsx tools/pack/Clean.ts",
    "node:dev": "tsx watch src/app.ts",
    "node:friend": "tsx src/friend.ts",
    "node:logger": "tsx src/logger.ts",
    "node:login": "tsx src/login.ts",
    "node:quickstart": "tsx src/app.ts",
    "node:setup": "tsx tools/server/setup.ts",
    "node:start": "npm i && tsx src/app.ts",
    "prepare": "husky",
    "quickstart": "bun run src/app.ts",
    "setup": "bun run tools/server/setup.ts",
    "sqlite:migrate": "prisma migrate deploy --schema prisma/singleworld/schema.prisma",
    "sqlite:reset": "prisma migrate reset --force --schema prisma/singleworld/schema.prisma",
    "sqlite:schema": "prisma migrate dev --schema prisma/singleworld/schema.prisma",
    "start": "bun install && bun run src/app.ts"
  },
  "lint-staged": {
    "*.{js,ts}": [
      "prettier --write",
      "eslint --no-warn-ignored"
    ]
  },
  "dependencies": {
    "@2004scape/rsbuf": "274.1.0",
    "@2004scape/rsmod-pathfinder": "^5.0.4",
    "@inquirer/prompts": "^8.0.1",
    "@isaacs/ttlcache": "^2.1.3",
    "@jimp/js-png": "^1.6.0",
    "@jimp/plugin-quantize": "^1.6.0",
    "@lostcityrs/runescript": "^0.9.6",
    "bcrypt": "^6.0.0",
    "ejs": "^3.1.10",
    "fflate": "^0.8.2",
    "jimp": "^1.6.0",
    "kleur": "^4.1.5",
    "kysely": "^0.28.8",
    "mysql2": "^3.15.3",
    "node-forge": "^1.3.2",
    "prom-client": "^15.1.3",
    "ws": "^8.18.3"
  },
  "optionalDependencies": {
    "better-sqlite3": "^11.8.1",
    "tsx": "^4.20.6"
  },
  "devDependencies": {
    "@eslint/js": "^9.39.1",
    "@types/bcrypt": "^6.0.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/bun": "latest",
    "@types/ejs": "^3.1.5",
    "@types/node": "^24.10.1",
    "@types/node-forge": "^1.3.14",
    "@types/ws": "^8.18.1",
    "eslint": "^9.39.1",
    "globals": "^16.5.0",
    "husky": "^9.1.7",
    "lint-staged": "^16.2.7",
    "prettier": "^3.7.3",
    "prisma": "^6.1.0",
    "prisma-kysely": "^2.2.1",
    "typescript-eslint": "^8.48.1"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
